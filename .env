# Spotify OAuth Credentials
# IMPORTANT: Keep this file secret. Never commit to version control.
# Rotate these keys immediately if they're ever exposed publicly.

SPOTIFY_CLIENT_ID=305badaa9b684a8bb9f0b21b94f686bb
SPOTIFY_CLIENT_SECRET=cf6a526519204180aa31247ff68f243b

# Flask Security
FLASK_ENV=production
SECRET_KEY=dev-key-change-in-production-12345678901234567890

# Rate Limiting (OWASP defaults)
# Format: "requests per time_window"
RATE_LIMIT_GENERAL=100/hour
RATE_LIMIT_AUTH=20/hour
RATE_LIMIT_API=50/hour

# Request Size Limits
MAX_CONTENT_LENGTH=1048576

# CORS Configuration
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Logging
LOG_LEVEL=INFO
