# EXAMPLE CONFIG FILE - Copy to .env and fill in your values
# NEVER commit .env to version control!

# Spotify OAuth Credentials
# Get these from: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Flask Security Settings
FLASK_ENV=production
SECRET_KEY=generate-a-random-secret-key-at-least-32-characters

# Rate Limiting (OWASP defaults)
# Format: requests/time_period (e.g., "100/hour", "5/minute")
RATE_LIMIT_GENERAL=100/hour
RATE_LIMIT_AUTH=20/hour
RATE_LIMIT_API=50/hour

# Request Size Limits (in bytes)
MAX_CONTENT_LENGTH=1048576

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Logging
LOG_LEVEL=INFO
